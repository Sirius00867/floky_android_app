# ══════════════════════════════════════════════════════════════════════════════
# FLOKY — Variables de Entorno
# ══════════════════════════════════════════════════════════════════════════════
# Copia este archivo como `.env` y rellena los valores reales.
# NUNCA subas `.env` al repositorio — está en .gitignore.
#
# Prefijo EXPO_PUBLIC_: variables accesibles en el bundle de la app (cliente).
# ⚠️  No pongas aquí secretos de servidor — todo lo que tenga EXPO_PUBLIC_
#     queda embebido en el binario y es legible por cualquiera que descompile la app.
# ══════════════════════════════════════════════════════════════════════════════

# ── Dexcom OAuth API ──────────────────────────────────────────────────────────
# Obtén tus credenciales en: https://developer.dexcom.com
EXPO_PUBLIC_DEXCOM_CLIENT_ID=
EXPO_PUBLIC_DEXCOM_CLIENT_SECRET=
# true = Sandbox (datos de prueba) | false = Producción
EXPO_PUBLIC_DEXCOM_SANDBOX=true

# ── Groq AI (compañero conversacional) ───────────────────────────────────────
# Obtén tu clave en: https://console.groq.com
# La clave la introduce el usuario final en los Ajustes de la app;
# esta variable solo sirve como valor por defecto en desarrollo.
EXPO_PUBLIC_GROQ_API_KEY=

# ── Proxy CORS para hosting estático (Netlify / Vercel / GitHub Pages) ────────
# Solo necesario cuando la app se sirve como sitio estático sin servidor Node.js.
# En ese caso el proxy local /api/proxy no funciona y hay que usar uno externo.
#
# OPCIÓN RECOMENDADA (segura): Cloudflare Worker propio
#   Despliega el worker de ejemplo en docs/cloudflare-worker-proxy.md
#   y pon aquí su URL: https://tu-worker.tu-cuenta.workers.dev/?url=
#
# OPCIÓN ALTERNATIVA (pública, no recomendada para datos reales):
#   EXPO_PUBLIC_CORS_PROXY_URL=https://corsproxy.io/?
#   ⚠️  Las credenciales de Nightscout / LibreLink / Dexcom / Tidepool
#       pasarían por un servidor de terceros. No uses esta opción con
#       credenciales reales en producción.
#
# Para desarrollo local con `npx expo start --web` deja esta variable vacía:
# el proxy Expo Router en /api/proxy se encarga automáticamente.
EXPO_PUBLIC_CORS_PROXY_URL=

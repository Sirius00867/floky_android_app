# ══════════════════════════════════════════════════════════════════════════════
# FLOKY — Variables de Entorno
# ══════════════════════════════════════════════════════════════════════════════
# Copia este archivo como `.env` y rellena los valores reales.
# NUNCA subas `.env` al repositorio — está en .gitignore.
#
# Prefijo EXPO_PUBLIC_: variables accesibles en el bundle de la app (cliente).
# ⚠️  No pongas aquí secretos de servidor — todo lo que tenga EXPO_PUBLIC_
#     queda embebido en el binario y es legible por cualquiera que descompile la app.
# ══════════════════════════════════════════════════════════════════════════════

# ── Dexcom OAuth API ──────────────────────────────────────────────────────────
# Obtén tus credenciales en: https://developer.dexcom.com
EXPO_PUBLIC_DEXCOM_CLIENT_ID=
EXPO_PUBLIC_DEXCOM_CLIENT_SECRET=
# true = Sandbox (datos de prueba) | false = Producción
EXPO_PUBLIC_DEXCOM_SANDBOX=true

# ── Groq AI (compañero conversacional) ───────────────────────────────────────
# Obtén tu clave en: https://console.groq.com
# La clave la introduce el usuario final en los Ajustes de la app;
# esta variable solo sirve como valor por defecto en desarrollo.
EXPO_PUBLIC_GROQ_API_KEY=

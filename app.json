{
  "expo": {
    "name": "Floky",
    "slug": "floky",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "floky",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.floky.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Floky lee tus lecturas de glucosa para mostrarte tu historial y tendencias del día.",
        "NSHealthUpdateUsageDescription": "Floky puede guardar registros de glucosa en Apple Health.",
        "NSMicrophoneUsageDescription": "Floky usa el micrófono para las funciones de audio y accesibilidad.",
        "NSUserNotificationsUsageDescription": "Floky envía recordatorios y alertas de glucosa para ayudarte a gestionar tu diabetes.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.floky.app",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png",
      "name": "Floky",
      "shortName": "Floky",
      "description": "App gamificada para adolescentes con diabetes tipo 1 y dislexia.",
      "lang": "es",
      "themeColor": "#208AEF",
      "backgroundColor": "#208AEF",
      "display": "standalone",
      "orientation": "portrait",
      "scope": "/",
      "startUrl": "/"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/icon.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#208AEF",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "enableHermes": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-asset",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee9d0277-91ff-45fd-a200-480263399923"
      }
    },
    "owner": "cefo"
  }
}
